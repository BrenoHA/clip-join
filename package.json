{
  "name": "clip-join",
  "version": "1.0.0",
  "description": "ClipJoin — an interactive terminal UI for joining videos into one file.",
  "type": "module",
  "license": "MIT",
  "author": "BrenoHA",
  "packageManager": "pnpm@10.17.1",
  "keywords": [
    "video",
    "ffmpeg",
    "cli",
    "tui",
    "ink",
    "concat",
    "join"
  ],
  "bin": {
    "clip-join": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
