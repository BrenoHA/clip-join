{
  "name": "clip-join",
  "version": "1.0.2",
  "description": "ClipJoin — an interactive terminal UI for joining videos into one file.",
  "type": "module",
  "license": "MIT",
  "author": "BrenoHA",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrenoHA/clip-join.git"
  },
  "homepage": "https://github.com/BrenoHA/clip-join#readme",
  "bugs": {
    "url": "https://github.com/BrenoHA/clip-join/issues"
  },
  "keywords": [
    "video",
    "ffmpeg",
    "cli",
    "tui",
    "ink",
    "concat",
    "join"
  ],
  "bin": {
    "clipjoin": "dist/index.js",
    "clip-join": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "happy-dom": "^20.10.6",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
